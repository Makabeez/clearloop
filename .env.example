# Local anvil is the default — leave this whole file unset for `npm run e2e`.
# To target Arc testnet, copy to .env and fill in DEPLOYER_KEY / AGENT_KEYS /
# CLEARINGHOUSE_ADDRESS. The rest are the real Arc testnet values.

# --- network (Arc testnet) ---
RPC_URL=https://rpc.testnet.arc.network
CHAIN_ID=5042002
CHAIN_NAME=arc-testnet
GAS_SYMBOL=USDC
EXPLORER_URL=https://testnet.arcscan.app

# --- USDC ---
# USDC is Arc's native gas token and exposes an ERC-20 interface at this system address:
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# --- accounts (fund each from https://faucet.circle.com -> Arc Testnet, 20 USDC / 2h) ---
DEPLOYER_KEY=0x...            # settler + deployer
AGENT_KEYS=0x...,0x...,0x...  # Alice,Bob,Carol - each needs faucet USDC for gas + deposit

# --- your deployment ---
# From (in clearloop-kit): forge script script/Deploy.s.sol --rpc-url $RPC_URL --private-key $DEPLOYER_KEY --broadcast
CLEARINGHOUSE_ADDRESS=0x...

# --- sizing (keeps deposits within the faucet limit) ---
AMOUNT_USDC=0.05             # base unit -> deposits 5 USDC/agent, obligations 0.5-2 USDC
# EPOCH=1                    # bump each run; a settled epoch id can't be reused
# KIT_OUT=../clearloop-kit/out
